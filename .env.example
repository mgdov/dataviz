# PostgreSQL
POSTGRES_DB=dataviz
POSTGRES_USER=dataviz
POSTGRES_PASSWORD=dataviz

# JWT (обязательно замените Jwt__Key в production!)
JWT_ISSUER=DataViz
JWT_AUDIENCE=DataViz.Web
JWT_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_BYTES
JWT_EXPIRE_MINUTES=480

# CORS (где будет крутиться фронт)
CORS_ORIGINS=http://localhost:3000

# Адрес API, который Next.js использует на клиенте
NEXT_PUBLIC_API_BASE=http://localhost:5080
