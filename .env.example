# PostgreSQL
POSTGRES_DB=dataviz
POSTGRES_USER=dataviz
POSTGRES_PASSWORD=dataviz

# JWT — JWT_KEY обязателен в production, минимум 32 байта (RFC 7518).
# Сгенерировать: `openssl rand -base64 48` или `head -c 48 /dev/urandom | base64`
JWT_ISSUER=DataViz
JWT_AUDIENCE=DataViz.Web
JWT_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_BYTES__USE_OPENSSL_RAND_BASE64_48
JWT_EXPIRE_MINUTES=480

# CORS — список разрешённых origin'ов фронта (через запятую)
CORS_ORIGINS=http://localhost:3000

# Адрес API, который Next.js использует на клиенте
NEXT_PUBLIC_API_BASE=http://localhost:5080

# Сидинг демо-данных. true — заполнить категории, товары и ~1500 заказов
# при первом старте. Также создаётся демо-пользователь demo@example.com / demo12345.
SEED_DATA=true

# Логин/пароль администратора, который будет создан при пустой БД.
# Если ADMIN_PASSWORD не указан, будет сгенерирован случайный 20-символьный
# пароль и выведен в лог при первом старте контейнера API.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345
